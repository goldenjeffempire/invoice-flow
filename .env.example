# InvoiceFlow Environment Configuration
# Copy this file to .env and fill in your values
# The application will fail fast on missing required variables

# =============================================================================
# REQUIRED: Core Settings (Application will not start without these)
# =============================================================================
DATABASE_URL=postgres://user:password@localhost:5432/invoiceflow
SECRET_KEY=your-secret-key-here-min-50-chars-use-python-c-import-secrets-print-secrets.token_urlsafe-50
ENCRYPTION_SALT=your-encryption-salt-generate-with-secrets-token-hex-32

# =============================================================================
# ENVIRONMENT MODE
# =============================================================================
PRODUCTION=false
DEBUG=true
DJANGO_SETTINGS_MODULE=invoiceflow.settings

# =============================================================================
# REQUIRED IN PRODUCTION: Email Configuration (SendGrid)
# =============================================================================
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key

# Email addresses
DEFAULT_FROM_EMAIL=Invoice Flow <noreply@invoiceflow.com.ng>
FROM_EMAIL=team@invoiceflow.com.ng
SENDGRID_FROM_EMAIL=noreply@invoiceflow.com.ng
SUPPORT_EMAIL=support@invoiceflow.com.ng

# =============================================================================
# OPTIONAL: Security Features
# =============================================================================
HCAPTCHA_SITEKEY=your-hcaptcha-site-key
HCAPTCHA_SECRET=your-hcaptcha-secret-key

# =============================================================================
# OPTIONAL: Payment Processing
# =============================================================================
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# =============================================================================
# OPTIONAL: Error Tracking
# =============================================================================
SENTRY_DSN=your-sentry-dsn

# =============================================================================
# PRODUCTION: Domain and Host Configuration
# =============================================================================
# ALLOWED_HOSTS=invoiceflow.com.ng,.invoiceflow.com.ng,www.invoiceflow.com.ng
# CSRF_TRUSTED_ORIGINS=https://invoiceflow.com.ng,https://www.invoiceflow.com.ng
# API_BASE_URL=https://invoiceflow.com.ng
# WEBHOOK_BASE_URL=https://invoiceflow.com.ng

# =============================================================================
# PRODUCTION: Gunicorn Settings
# =============================================================================
# GUNICORN_LOG_LEVEL=info
# GUNICORN_THREADS=4
# GUNICORN_WORKER_CLASS=gthread
# WEB_CONCURRENCY=4

# =============================================================================
# RENDER DEPLOYMENT (auto-populated by Render)
# =============================================================================
# RENDER=true
# RENDER_SERVICE_NAME=invoiceflow
# RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com
