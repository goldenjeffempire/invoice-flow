modules = ["web", "nodejs-20", "bash", "python-3.11"]
[nix]
channel = "stable-25_05"
packages = ["awsebcli", "cairo", "cargo", "fontconfig", "freetype", "gdk-pixbuf", "ghostscript", "glib", "gobject-introspection", "harfbuzz", "lcms2", "libffi", "libiconv", "libimagequant", "libjpeg", "libpq", "libtiff", "libwebp", "libxcrypt", "libyaml", "openjpeg", "openssl", "pango", "pgadmin4", "pkg-config", "postgresql", "rustc", "shared-mime-info", "sqlite", "tcl", "tk", "unzip", "zlib"]

[agent]
expertMode = true
integrations = ["sendgrid:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Django Development Server"

[[workflows.workflow]]
name = "Django Development Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python manage.py runserver 0.0.0.0:5000"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
SENDGRID_FROM_EMAIL = "noreply@invoiceflow.com.ng"
SECRET_KEY = "P-xsqzlcYttOpntIDZTUkRkcE1YDsu6H9z1zcj1-woUtnppOPr2Ht-lJn4UTTqvu3eo"
ENCRYPTION_SALT = "d23404b518e957b03bc7f23e1ee79de5b964e9feedc2ccdb1a4d4aa010275d15"

[userenv.development]
DEBUG = "True"
PRODUCTION = "false"
ALLOWED_HOSTS = "*"

[userenv.production]
DEBUG = "False"
PRODUCTION = "true"
ALLOWED_HOSTS = "invoiceflow.com.ng,.invoiceflow.com.ng,www.invoiceflow.com.ng"

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--workers=2", "--threads=4", "--timeout=120", "--worker-class=gthread", "invoiceflow.wsgi:application"]
build = ["python", "-c", "import django; django.setup()"]
