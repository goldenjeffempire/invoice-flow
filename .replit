modules = ["web", "nodejs-20", "python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["cairo", "cargo", "fontconfig", "freetype", "gdk-pixbuf", "ghostscript", "glib", "glibcLocales", "gobject-introspection", "harfbuzz", "lcms2", "libffi", "libiconv", "libimagequant", "libjpeg", "libpng", "libtiff", "libwebp", "libxcrypt", "libyaml", "openjpeg", "openssl", "pango", "pgadmin4", "pkg-config", "postgresql", "rustc", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "InvoiceFlow"

[[workflows.workflow]]
name = "InvoiceFlow"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python manage.py runserver 0.0.0.0:5000"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "invoiceflow.wsgi:application", "--bind", "0.0.0.0:5000", "--workers", "2", "--threads", "4", "--worker-class", "gthread", "--timeout", "120"]
build = ["pip", "install", "-r", "requirements.txt"]

[userenv]

[userenv.shared]
DATABASE_URL = "postgresql://neondb_owner:npg_2SvpMxdeZ5QO@ep-floral-term-agnjt8fb-pooler.c-2.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

[userenv.development]
DEBUG = "True"
ENCRYPTION_SALT = "replit-dev-salt-1234567890123456"
SECRET_KEY = "django-insecure-replit-secret-key-for-dev-only-12345"

[userenv.production]
DEBUG = "False"
PRODUCTION = "true"
DJANGO_SETTINGS_MODULE = "invoiceflow.settings"
EMAIL_HOST = "smtp.sendgrid.net"
EMAIL_HOST_USER = "apikey"
EMAIL_PORT = "587"
EMAIL_USE_TLS = "True"
DEFAULT_FROM_EMAIL = "Invoice Flow <noreply@invoiceflow.com.ng>"
FROM_EMAIL = "team@invoiceflow.com.ng"
SENDGRID_FROM_EMAIL = "noreply@invoiceflow.com.ng"
SUPPORT_EMAIL = "support@invoiceflow.com.ng"
API_BASE_URL = "https://invoiceflow.com.ng"
WEBHOOK_BASE_URL = "https://invoiceflow.com.ng"
ALLOWED_HOSTS = "invoiceflow.com.ng,.invoiceflow.com.ng,www.invoiceflow.com.ng,invoice-flow-7vu0.onrender.com"
CSRF_TRUSTED_ORIGINS = "https://invoiceflow.com.ng,https://www.invoiceflow.com.ng"
GUNICORN_LOG_LEVEL = "info"
GUNICORN_THREADS = "4"
GUNICORN_WORKER_CLASS = "gthread"
WEB_CONCURRENCY = "4"
RENDER = "true"
RENDER_SERVICE_NAME = "invoiceflow"
