# Production Environment Variables for Render
# These are EXAMPLES - set actual values in Render Dashboard > Environment

# Django Security
SECRET_KEY=change-me-in-render-dashboard
ENCRYPTION_SALT=change-me-in-render-dashboard

# hCaptcha (optional for form protection)
HCAPTCHA_SITEKEY=change-me-in-render-dashboard
HCAPTCHA_SECRET=change-me-in-render-dashboard

# Email Service (SendGrid)
SENDGRID_API_KEY=change-me-in-render-dashboard
